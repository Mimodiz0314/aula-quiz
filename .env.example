# --- Firebase Realtime Database ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# --- IA: clave del servidor (NUNCA con prefijo VITE_, se expondría al cliente) ---
# La generación de actividades corre en /api/generar (serverless en Vercel).
# Configura esta variable en el panel de Vercel, no en el bundle del frontend.
# GROQ_API_KEY=

# --- Opcional: base URL del endpoint de IA (déjalo vacío si /api vive en el mismo dominio) ---
# VITE_API_BASE_URL=
