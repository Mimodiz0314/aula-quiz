{
  "rules": {
    "usuarios": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid && !root.child('usuarios').exists()"
      }
    },
    "sesiones": {
      ".read": false,
      ".write": false,
      "$pin": {
        ".read": true,
        ".write": "auth != null && auth.token.email != null",
        "preguntas": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "estado_actual": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "pregunta_idx": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "pregunta_inicio_ts": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "pregunta_duracion": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "estudiantes": {
          ".read": true,
          "$studentId": {
            ".write": "auth != null",
            "respuestas_registradas": {
              ".write": "auth != null && (data.parent().child('uid').val() == auth.uid || auth.token.email != null)"
            }
          }
        }
      }
    },
    "banco_preguntas": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('usuarios').child(auth.uid).child('rol').val() === 'admin')",
        ".write": "auth != null && auth.uid === $uid && root.child('usuarios').child(auth.uid).child('activo').val() === true"
      }
    }
  }
}
