{
  "rules": {
    "usuarios": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'admin'",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('usuarios').child(auth.uid).child('rol').val() === 'admin')",
        ".write": "auth != null && (root.child('usuarios').child(auth.uid).child('rol').val() === 'admin' || (auth.uid === $uid && !data.exists() && (newData.child('rol').val() === 'docente' || !root.child('usuarios').exists())))"
      }
    },
    "sesiones": {
      ".read": false,
      ".write": false,
      "$pin": {
        ".read": true,
        ".write": "auth != null && auth.token.email != null",
        "preguntas": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "estado_actual": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "pregunta_idx": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "pregunta_inicio_ts": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "pregunta_duracion": {
          ".read": true,
          ".write": "auth != null && auth.token.email != null"
        },
        "estudiantes": {
          ".read": true,
          "$studentId": {
            ".write": "auth.token.email != null || (auth != null && !data.exists() && newData.child('uid').val() === auth.uid)",
            "respuestas_registradas": {
              ".write": "auth != null && (data.parent().child('uid').val() === auth.uid || auth.token.email != null)"
            },
            "tiempos_respuesta": {
              ".write": "auth != null && (data.parent().child('uid').val() === auth.uid || auth.token.email != null)"
            },
            "conectado": {
              ".write": "auth != null && (data.parent().child('uid').val() === auth.uid || auth.token.email != null)"
            },
            "uid": {
              ".write": "auth.token.email != null || (auth != null && newData.val() === auth.uid)"
            }
          }
        }
      }
    },
    "claves": {
      ".read": false,
      ".write": false,
      "$pin": {
        ".read": "auth != null && auth.token.email != null",
        ".write": "auth != null && auth.token.email != null"
      }
    },
    "banco_preguntas": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('usuarios').child(auth.uid).child('rol').val() === 'admin')",
        ".write": "auth != null && auth.uid === $uid && root.child('usuarios').child(auth.uid).child('activo').val() === true"
      }
    },
    "historial": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "banco_comunidad": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null"
    },
    "ai_training_logs": {
      ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'admin'",
      ".write": "auth != null && auth.token.email != null"
    },
    "configuracion_ia": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'admin'"
    },
    "foro": {
      "categorias": {
        ".read": "auth != null",
        ".write": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'admin'"
      },
      "hilos": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email != null"
      },
      "respuestas": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email != null"
      },
      "reportes": {
        ".read": "auth != null && root.child('usuarios').child(auth.uid).child('rol').val() === 'admin'",
        ".write": "auth != null && auth.token.email != null"
      }
    }
  }
}
